# =============================================================================
# Vinguard frontend (Vite) — copy to .env for local development
#   cp .env.example .env
# Variables must be prefixed with VITE_ to be exposed to the app.
# =============================================================================

# Base URL of the backend tRPC endpoint (include /trpc).
# If unset, the app defaults to http://localhost:3000/trpc
VITE_API_URL=http://localhost:3000/trpc

# -----------------------------------------------------------------------------
# Production builds
# -----------------------------------------------------------------------------
# For `bun run build` / hosted deploys, either:
#   - copy this file to .env.production with your real API URL, or
#   - set VITE_API_URL in the CI/hosting environment before build.
# The value is baked into the client at build time.
