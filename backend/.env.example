# =============================================================================
# Vinguard backend — copy to .env and fill values
#   cp .env.example .env
# Bun loads .env automatically when you run `bun run dev` or `bun run worker`.
# =============================================================================

# --- HTTP server ---
# Port for the Hono + tRPC API (default 3000 if unset)
APP_PORT=3000

# Comma-separated browser origins allowed to call the API (CORS).
# Must include your Vite dev URL (default below matches Vite’s usual port).
CORS_ORIGIN=http://localhost:5173

# --- Palantir (required for cars, chat, LLM extraction, vehicle analysis) ---
# REST + AIP: same Foundry stack URL you use in the Palantir UI / API docs.
PALANTIR_FOUNDRY_API_URL=https://your-stack.palantirfoundry.com

# Ontology resource id for the `cars` object type (ri.ontology...).
PALANTIR_ONTOLOGY_RID=

# Bearer token for AIP / ontology HTTP calls (LLM + object actions).
PALANTIR_AIP_API_KEY=

# --- Auth (JWT for register/login) ---
# Use a long random string in production; default in code is insecure.
JWT_SECRET=change-me-to-a-long-random-string

# --- SQLite (job queue + local users) ---
# File path for the Bun SQLite database (created on first run; migrations run at startup).
DB_FILE_NAME=database.sqlite

# --- Cloudflare R2 (CarFax PDF presigned upload/download) ---
# Required for new-report PDF upload flow. S3-compatible endpoint from R2 dashboard.
R2_BASE_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Optional ---
# Log level for winston: error, warn, info, debug, etc.
# LOG_LEVEL=info

# Set to "true" on the worker process for verbose job-queue debug logs.
# VERBOSE=false

# Docker / data volume root (only if you deploy with VOLUME_PATH set).
# VOLUME_PATH=/app/data

# OSDK client credentials — only needed if you use scripts under src/foundry/
# PALANTIR_SDK_CLIENT_ID=
# PALANTIR_SDK_CLIENT_SECRET=
